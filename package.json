{
  "name": "small-business-tracker",
  "version": "0.1.0",
  "scripts": {
    "lint": "eslint --config eslint.config.mjs --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "eslint --config eslint.config.mjs --ext .js,.jsx,.ts,.tsx . --fix",
    "lint:ci": "npm run lint --silent --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "quality": "node scripts/quality-runner.js",
    "quality:ci": "node scripts/quality-runner.js --ci",
    "dev": "next dev",
    "build": "next build --no-lint",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:single": "jest --testNamePattern"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@playwright/test": "^1.58.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/themes": "^3.0.0",
    "@slack/webhook": "^7.0.6",
    "@supabase/auth-js": "^2.91.1",
    "@supabase/supabase-js": "^2.91.1",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/react-query-devtools": "^5.91.2",
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.0.6",
    "fast-xml-parser": "^4.5.5",
    "lucide-react": "^0.459.0",
    "next": "^14.2.15",
    "next-auth": "^5.0.0-beta.30",
    "node-cron": "^4.2.1",
    "pino": "^10.2.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
